# Loaded by core/config.py when ENV=test is exported (e.g. by tests/conftest.py).
# Single Postgres instance on port 5433 — both CRM and LOCAL test data live in
# the same database `test_db_be` declared in tests/docker-compose.test.yml.

# ── Core ──
ENV=test

# ── CRM database (mirrored CRM tables created by tests/sql/crm_test_schema.sql) ──
CRM_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/test_db_be
CRM_DB_POOL_SIZE=5
CRM_DB_MAX_OVERFLOW=2
CRM_DB_POOL_RECYCLE=3600
CRM_DB_POOL_TIMEOUT=10
CRM_DB_SSL=false

# ── Local database (schema applied from scripts/sql/schema.sql) ──
LOCAL_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/test_db_be
LOCAL_DB_POOL_SIZE=5
LOCAL_DB_MAX_OVERFLOW=2
LOCAL_DB_POOL_RECYCLE=3600
LOCAL_DB_POOL_TIMEOUT=10
LOCAL_DB_SSL=false

# ── NATS ──
# Empty: workers are not initialised under tests; NATS clients are mocked.
NATS_URL=

# ── Storage ──
# Placeholders only — tests mock core.storage entirely; nothing real is contacted.
STORAGE_ENDPOINT=http://localhost:9999
STORAGE_BUCKET=test-bucket
STORAGE_ACCESS_KEY=test-access
STORAGE_SECRET_KEY=test-secret
STORAGE_REGION=us-east-1

# ── CORS ──
ALLOW_ORIGIN=http://localhost

# ── Observability ──
# Empty: tracing/metrics exporters are no-ops without endpoints.
LOGGING_TOKEN=
LOGGING_TRACES_URL=
LOGGING_LOGS_URL=
LOGGING_METRICS_URL=
